{
  "name": "workboard-mcp",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx packages/functions/src/local.ts",
    "dev:sst": "sst dev",
    "db:local": "docker run --rm -p 5432:5432 -v $(pwd)/.sst/storage/postgres:/var/lib/postgresql/data -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=password -e POSTGRES_DB=workboard_mcp postgres:17",
    "generate:workboard": "tsx packages/scripts/src/generate-workboard.ts",
    "prune:workboard-sdk": "node packages/scripts/src/prune-generated-sdk-node-modules.mjs",
    "postinstall": "npm run prune:workboard-sdk",
    "auth:generate": "better-auth generate --config packages/core/src/auth/auth.ts --output packages/core/src/db/schema/auth.ts --yes && tsx packages/scripts/src/patch-better-auth-drizzle-schema.ts",
    "db:generate": "npm run auth:generate && drizzle-kit generate --config drizzle.config.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "migrate": "npm run migrate:app",
    "migrate:auth": "npm run auth:generate",
    "migrate:app": "drizzle-kit migrate --config drizzle.config.ts",
    "typecheck": "npm run prune:workboard-sdk && tsc -b packages/core packages/functions packages/scripts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tsconfig/node22": "^22",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "api": "^6.1.3",
    "drizzle-kit": "^1.0.0-rc.3",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@api/workboard-v1": "file:.api/apis/workboard-v1",
    "@api/workboard-v2": "file:.api/apis/workboard-v2",
    "@aws-sdk/client-rds-data": "^3.1074.0",
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@better-auth/oauth-provider": "^1.6.20",
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.3",
    "hono": "^4.12.26",
    "mcp-handler": "^1.1.0",
    "pg": "^8.22.0",
    "sst": "^4.15.2",
    "zod": "^4.4.3"
  }
}
